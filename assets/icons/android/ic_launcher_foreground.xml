<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — Radar Vital
  Viewport: 108 × 108 dp (Android adaptive icon spec).
  Safe zone: 66 dp centred (18 dp inset on each side).
  Motif: concentric radar arcs + heartbeat/pulse line.
  All paths use a single light colour (#FFFFFF) on transparent background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Concentric radar arcs — three quarter-circles opening to the right,
        centred at (54, 54), radii 14, 22, 30.  Each arc spans ~200° so the
        opening faces upper-right (the classic radar-sweep look).
        Stroke rendered as filled paths via explicit stroke geometry.
    -->

    <!-- Innermost arc  r=14, stroke ~2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
M 54,54
m -14,0
a 14,14 0 1 1 9.9,-9.9
l -1.8,1.8
a 11.5,11.5 0 1 0 -8.1,8.1
Z" />

    <!-- Middle arc  r=22, stroke ~2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
M 54,54
m -22,0
a 22,22 0 1 1 15.56,-15.56
l -1.8,1.8
a 19.5,19.5 0 1 0 -13.76,13.76
Z" />

    <!-- Outer arc  r=30, stroke ~2.5 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
M 54,54
m -30,0
a 30,30 0 1 1 21.21,-21.21
l -1.8,1.8
a 27.5,27.5 0 1 0 -19.41,19.41
Z" />

    <!--
        Heartbeat / pulse line — horizontal baseline through the centre with
        a single ECG-style spike, confined within the 66 dp safe zone
        (x: 21..87, y: 54 centre).  Rendered as a filled thin-stroke path.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
M 21,54.5
L 41,54.5
L 44,47
L 48,62
L 52,50
L 56,58
L 59,54.5
L 87,54.5
L 87,55.5
L 59,55.5
L 55.2,59.5
L 51.8,51
L 47.8,63.5
L 43.5,48
L 41,55.5
L 21,55.5
Z" />

    <!-- Centre dot — radar origin -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 54,54 m -2.5,0 a 2.5,2.5 0 1 0 5,0 a 2.5,2.5 0 1 0 -5,0 Z" />

</vector>
