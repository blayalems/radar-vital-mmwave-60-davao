{
  "name": "radar-vital-mobile",
  "version": "16.4.0",
  "private": true,
  "description": "Mobile-first PWA shell for the Radar Vital mmWave 60 GHz trainer. Capacitor APK + Tauri EXE + GitHub Pages.",
  "type": "module",
  "scripts": {
    "extract:monolith": "node scripts/extract-monolith.mjs",
    "build:web": "node scripts/build-angular.mjs",
    "build:check": "node scripts/check-roundtrip.mjs",
    "test": "playwright test tests/smoke",
    "test:all": "playwright test",
    "test:source-integrity": "node scripts/check-source-integrity.mjs",
    "test:contrast": "node scripts/check-contrast-tokens.mjs",
    "test:unit:web": "npm run test:source-integrity && npm run test:contrast && npm --prefix web run test:ci",
    "test:smoke": "playwright test tests/smoke",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots",
    "cap:sync": "npm run build:web && cap sync android && node scripts/patch-android-shell.mjs",
    "cap:open:android": "cap open android",
    "tauri:dev": "npm run build:web && tauri dev",
    "tauri:build": "npm run build:web && tauri build"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@playwright/test": "^1.55.1",
    "@tauri-apps/cli": "^2.11.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^7.1.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/splash-screen": "^7.0.5",
    "@capacitor/status-bar": "^7.0.6"
  },
  "engines": {
    "node": ">=20"
  }
}
