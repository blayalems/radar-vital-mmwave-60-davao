{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capability for the Radar Vital main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/rvt-trainer",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "https://github.com/*"
        }
      ]
    }
  ]
}
