{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Radar Vital",
  "version": "16.2.0",
  "identifier": "com.blayalems.radarvital",
  "build": {
    "frontendDist": "../capacitor/www",
    "beforeBuildCommand": "cd ../capacitor && npm run prepare:www"
  },
  "app": {
    "windows": [
      {
        "title": "Radar Vital",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
